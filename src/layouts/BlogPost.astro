---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import AdSlot from '../components/AdSlot.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CALCULATORS, CATEGORIES } from '../consts';

interface RelatedPost {
	id: string;
	title: string;
	description: string;
	category: string;
	pubDate: Date;
}

type Props = CollectionEntry<'blog'>['data'] & {
	wordCount?: number;
	related?: RelatedPost[];
};

const { title, description, pubDate, updatedDate, heroImage, category, tags, wordCount, related } =
	Astro.props;
const cat = CATEGORIES.find((c) => c.slug === category);
const readingMinutes = wordCount ? Math.max(1, Math.round(wordCount / 350)) : null;

// 카테고리별 추천 계산기 (내부링크·체류시간 강화)
const CALC_BY_CAT: Record<string, string[]> = {
	realestate: ['acquisition-tax', 'brokerage-fee', 'subscription-score'],
	tax: ['acquisition-tax', 'brokerage-fee'],
	loan: ['dsr', 'jeonse-conversion'],
	subsidy: ['dsr', 'subscription-score'],
	business: ['brokerage-fee', 'dsr'],
	calculator: ['acquisition-tax', 'dsr', 'brokerage-fee'],
	news: ['acquisition-tax', 'dsr'],
};
const promoCalcs = (CALC_BY_CAT[category ?? 'news'] ?? [])
	.map((slug) => CALCULATORS.find((c) => c.slug === slug))
	.filter(Boolean)
	.slice(0, 3);
---

<html lang="ko">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			article={{
				pubDate,
				updatedDate,
				category: cat?.label ?? category,
				tags,
				author: '인포모아',
			}}
		/>
	</head>
	<body>
		<Header />
		<main id="main">
			<article class="post">
				{
					heroImage && (
						<div class="hero-image">
							<Image src={heroImage} alt={title} width={1200} height={630} />
						</div>
					)
				}
				<div class="prose post-prose">
					<header class="post-header">
						{
							cat && (
								<a href={`/category/${cat.slug}/`} class="cat-badge">
									<span aria-hidden="true">{cat.emoji}</span> {cat.label}
								</a>
							)
						}
						<h1 class="post-title">{title}</h1>
						<p class="post-lead">{description}</p>
						<div class="post-meta">
							<span>
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<>
										{' '}<span class="meta-sep">·</span> 수정{' '}<FormattedDate date={updatedDate} />
									</>
								)}
							</span>
							{readingMinutes && (
								<>
									<span class="meta-sep" aria-hidden="true">·</span>
									<span>약 {readingMinutes}분</span>
								</>
							)}
							{tags && tags.length > 0 && (
								<>
									<span class="meta-sep" aria-hidden="true">·</span>
									<span class="tag-list">
										{tags.slice(0, 5).map((t) => (
											<span class="tag">#{t}</span>
										))}
									</span>
								</>
							)}
						</div>
					</header>
					<slot />

					{
						promoCalcs.length > 0 && (
							<aside class="calc-promo" aria-label="관련 계산기">
								<p class="calc-promo-title">🧮 이 글과 관련된 계산기</p>
								<ul class="calc-cross">
									{promoCalcs.map((c) => (
										<li>
											<a href={`/calculator/${c!.slug}/`}>
												<span class="name">
													{c!.emoji} {c!.name}
												</span>
												{c!.short}
											</a>
										</li>
									))}
								</ul>
							</aside>
						)
					}

					<AffiliateCTA category={category} />
				</div>

				<AdSlot />

				{
					related && related.length > 0 && (
						<section class="related" aria-labelledby="related-heading">
							<h2 id="related-heading">함께 보면 좋은 글</h2>
							<ul class="related-grid">
								{related.map((r) => {
									const rcat = CATEGORIES.find((c) => c.slug === r.category);
									return (
										<li>
											<a href={`/blog/${r.id}/`}>
												<p class="related-meta">
													{rcat && (
														<span class="related-cat">
															<span aria-hidden="true">{rcat.emoji}</span> {rcat.label}
														</span>
													)}
													<FormattedDate date={r.pubDate} />
												</p>
												<p class="related-title">{r.title}</p>
											</a>
										</li>
									);
								})}
							</ul>
						</section>
					)
				}
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: var(--space-6) var(--space-4) var(--space-8);
	}
	.hero-image {
		max-width: var(--container-lg);
		margin: 0 auto var(--space-6);
	}
	.hero-image :global(img) {
		width: 100%;
		height: auto;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-md);
	}
	.post-prose {
		max-width: var(--content-prose);
		margin: 0 auto;
	}
	.post-header {
		margin-bottom: var(--space-6);
		padding-bottom: var(--space-5);
		border-bottom: 1px solid var(--border-default);
	}
	.post-title {
		margin: var(--space-3) 0 var(--space-3);
		font-size: var(--text-4xl);
		font-weight: var(--weight-extrabold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
	}
	@media (max-width: 768px) {
		.post-title {
			font-size: var(--text-3xl);
		}
	}
	.post-lead {
		margin: 0 0 var(--space-4);
		font-size: var(--text-lg);
		color: var(--text-meta);
		line-height: var(--leading-snug);
	}
	.post-meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		font-size: var(--text-sm);
		color: var(--text-meta);
		align-items: center;
	}
	.meta-sep {
		color: var(--color-gray-300);
	}
	.tag-list {
		display: inline-flex;
		gap: var(--space-2);
		flex-wrap: wrap;
	}
	.tag {
		color: var(--text-link);
		font-weight: var(--weight-medium);
	}
	.calc-promo {
		margin-top: var(--space-7);
		padding-top: var(--space-5);
		border-top: 1px solid var(--border-default);
	}
	.calc-promo-title {
		font-weight: var(--weight-bold);
		color: var(--text-heading);
		margin: 0;
	}
	.related {
		max-width: var(--content-prose);
		margin: var(--space-7) auto 0;
	}
	.related h2 {
		font-size: var(--text-2xl);
		margin: 0 0 var(--space-4);
	}
	.related-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-3);
		list-style: none;
		margin: 0;
		padding: 0;
	}
	@media (max-width: 640px) {
		.related-grid {
			grid-template-columns: 1fr;
		}
	}
	.related-grid a {
		display: block;
		padding: var(--space-4);
		background: var(--bg-card);
		border: 1px solid var(--border-default);
		border-radius: var(--radius-md);
		text-decoration: none;
		color: inherit;
		height: 100%;
	}
	.related-grid a:hover {
		border-color: var(--color-primary-300);
		box-shadow: var(--shadow-md);
		text-decoration: none;
	}
	.related-meta {
		display: flex;
		gap: var(--space-2);
		font-size: var(--text-xs);
		color: var(--text-meta);
		margin: 0 0 var(--space-2);
		align-items: center;
		flex-wrap: wrap;
	}
	.related-cat {
		color: var(--text-link);
		font-weight: var(--weight-semibold);
	}
	.related-title {
		margin: 0;
		font-weight: var(--weight-semibold);
		color: var(--text-heading);
		line-height: var(--leading-snug);
		font-size: var(--text-base);
	}
</style>
