---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { wordCount?: number };

const { title, description, pubDate, updatedDate, heroImage, category, tags, wordCount } =
	Astro.props;
const cat = CATEGORIES.find((c) => c.slug === category);
const readingMinutes = wordCount ? Math.max(1, Math.round(wordCount / 350)) : null;
---

<html lang="ko">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			article={{
				pubDate,
				updatedDate,
				category: cat?.label ?? category,
				tags,
				author: '인포모아',
			}}
		/>
	</head>
	<body>
		<Header />
		<main id="main">
			<article class="post">
				{
					heroImage && (
						<div class="hero-image">
							<Image src={heroImage} alt={title} width={1200} height={630} />
						</div>
					)
				}
				<div class="prose post-prose">
					<header class="post-header">
						{
							cat && (
								<a href={`/category/${cat.slug}/`} class="cat-badge">
									<span aria-hidden="true">{cat.emoji}</span> {cat.label}
								</a>
							)
						}
						<h1 class="post-title">{title}</h1>
						<p class="post-lead">{description}</p>
						<div class="post-meta">
							<span>
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<>
										{' '}<span class="meta-sep">·</span> 수정{' '}<FormattedDate date={updatedDate} />
									</>
								)}
							</span>
							{readingMinutes && (
								<>
									<span class="meta-sep" aria-hidden="true">·</span>
									<span>약 {readingMinutes}분</span>
								</>
							)}
							{tags && tags.length > 0 && (
								<>
									<span class="meta-sep" aria-hidden="true">·</span>
									<span class="tag-list">
										{tags.slice(0, 5).map((t) => (
											<span class="tag">#{t}</span>
										))}
									</span>
								</>
							)}
						</div>
					</header>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: var(--space-6) var(--space-4) var(--space-8);
	}
	.hero-image {
		max-width: var(--container-lg);
		margin: 0 auto var(--space-6);
	}
	.hero-image :global(img) {
		width: 100%;
		height: auto;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-md);
	}
	.post-prose {
		max-width: var(--content-prose);
		margin: 0 auto;
	}
	.post-header {
		margin-bottom: var(--space-6);
		padding-bottom: var(--space-5);
		border-bottom: 1px solid var(--border-default);
	}
	.post-title {
		margin: var(--space-3) 0 var(--space-3);
		font-size: var(--text-4xl);
		font-weight: var(--weight-extrabold);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
	}
	@media (max-width: 768px) {
		.post-title {
			font-size: var(--text-3xl);
		}
	}
	.post-lead {
		margin: 0 0 var(--space-4);
		font-size: var(--text-lg);
		color: var(--text-meta);
		line-height: var(--leading-snug);
	}
	.post-meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		font-size: var(--text-sm);
		color: var(--text-meta);
		align-items: center;
	}
	.meta-sep {
		color: var(--color-gray-300);
	}
	.tag-list {
		display: inline-flex;
		gap: var(--space-2);
		flex-wrap: wrap;
	}
	.tag {
		color: var(--text-link);
		font-weight: var(--weight-medium);
	}
</style>
