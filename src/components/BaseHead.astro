---
import '../styles/global.css';
import { SITE_TITLE, SITE_DESCRIPTION, ADSENSE_CLIENT, GA_MEASUREMENT_ID } from '../consts';
import type { CollectionEntry } from 'astro:content';

interface ArticleProps {
	pubDate: Date;
	updatedDate?: Date;
	category?: string;
	tags?: string[];
	author?: string;
}

interface Props {
	title: string;
	description: string;
	image?: string;
	article?: ArticleProps;
	type?: 'website' | 'article';
	noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
	title,
	description,
	image = '/og-default.png',
	article,
	type = 'website',
	noindex = false,
} = Astro.props;

const imageURL = new URL(image, Astro.site).toString();
const ogType = type === 'article' ? 'article' : 'website';

// JSON-LD: Organization + WebSite (모든 페이지 공통)
const baseLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': `${Astro.site}#organization`,
			name: '인포모아',
			url: Astro.site?.toString(),
			logo: {
				'@type': 'ImageObject',
				url: new URL('/favicon.svg', Astro.site).toString(),
			},
			description: '부동산·세금·금융·정부지원금·창업·계산기·뉴스 한국 생활정보 종합 블로그',
		},
		{
			'@type': 'WebSite',
			'@id': `${Astro.site}#website`,
			url: Astro.site?.toString(),
			name: SITE_TITLE,
			description: SITE_DESCRIPTION,
			publisher: { '@id': `${Astro.site}#organization` },
			inLanguage: 'ko-KR',
		},
	],
};

// 글 페이지일 때 BlogPosting 추가
const articleLd =
	article && type === 'article'
		? {
				'@context': 'https://schema.org',
				'@type': 'BlogPosting',
				'@id': `${canonicalURL.toString()}#article`,
				mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
				headline: title,
				description,
				image: imageURL,
				datePublished: article.pubDate.toISOString(),
				dateModified: (article.updatedDate ?? article.pubDate).toISOString(),
				author: {
					'@type': 'Person',
					name: article.author ?? '인포모아',
					url: new URL('/about', Astro.site).toString(),
				},
				publisher: { '@id': `${Astro.site}#organization` },
				articleSection: article.category,
				keywords: article.tags?.join(', '),
				inLanguage: 'ko-KR',
			}
		: null;
---

<!-- Charset & Viewport -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="color-scheme" content="light dark" />

<!-- Primary -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="인포모아" />
<meta name="publisher" content="인포모아" />
<meta name="generator" content={Astro.generator} />

<!-- Robots -->
{
	noindex ? (
		<meta name="robots" content="noindex, nofollow" />
	) : (
		<meta
			name="robots"
			content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
		/>
	)
}

<!-- Korean Locale -->
<meta http-equiv="content-language" content="ko-KR" />
<meta name="language" content="Korean" />

<!-- Canonical & Alternates -->
<link rel="canonical" href={canonicalURL} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={`${SITE_TITLE} RSS`}
	href={new URL('rss.xml', Astro.site)}
/>
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Icons & Theme -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<meta name="theme-color" content="#233480" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#131e48" media="(prefers-color-scheme: dark)" />

<!-- Font Preconnect (LCP 개선) -->
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
<link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="인포모아" />
<meta property="og:locale" content="ko_KR" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
{
	article && (
		<>
			<meta property="article:published_time" content={article.pubDate.toISOString()} />
			{article.updatedDate && (
				<meta property="article:modified_time" content={article.updatedDate.toISOString()} />
			)}
			{article.category && <meta property="article:section" content={article.category} />}
			{article.author && <meta property="article:author" content={article.author} />}
			{article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
		</>
	)
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<!-- 검색엔진 소유 확인 (메타 방식) -->
<!-- 네이버: 파일 방식은 CF/Astro가 .html 확장자 strip하며 307 redirect → 검증 실패. 메타로 우회. -->
<meta name="naver-site-verification" content="92ea6a8618e9cfc32e60824dc794f2ea" />
<!-- 구글: 코드 발급 후 주석 해제 -->
<!-- <meta name="google-site-verification" content="REPLACE_WITH_GOOGLE_CODE" /> -->

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(baseLd)} />
{articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}

<!-- Google AdSense (consts.ts 의 ADSENSE_CLIENT 설정 시에만 출력) -->
{
	ADSENSE_CLIENT && (
		<script
			async
			src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
			crossorigin="anonymous"
		/>
	)
}

<!-- Google Analytics 4 (consts.ts 의 GA_MEASUREMENT_ID 설정 시에만 출력) -->
{
	GA_MEASUREMENT_ID && (
		<>
			<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`} />
			<script
				is:inline
				set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_MEASUREMENT_ID}');`}
			/>
		</>
	)
}
