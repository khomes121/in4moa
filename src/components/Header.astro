---
import { CATEGORIES, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">블로그</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
		</div>
		<div class="social-links">
			<a href="/rss.xml" aria-label="RSS 구독" title="RSS 구독">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
					<path
						fill="currentColor"
						d="M3.428 12.572a1.428 1.428 0 1 1-2.856 0 1.428 1.428 0 0 1 2.856 0zM.572 4.286v2.143c4.844 0 8.857 4.013 8.857 8.857h2.143C11.572 8.857 6.715 4 .572 4zM.572.572v2.143c7.286 0 13.143 5.857 13.143 13.143h2.143C15.858 7.288 9.288.572.572.572z"
					></path>
				</svg>
			</a>
		</div>
	</nav>
	<div class="category-strip">
		{
			CATEGORIES.map((c) => (
				<a class="cat-chip" href={`/category/${c.slug}/`}>
					<span aria-hidden="true">{c.emoji}</span> {c.label}
				</a>
			))
		}
	</div>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1.15em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.category-strip {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		padding: 0.5em 0 0.8em;
		border-top: 1px solid rgba(var(--gray-light), 1);
	}
	.cat-chip {
		padding: 0.35em 0.7em;
		border-radius: 999px;
		background: rgba(var(--gray-light), 0.6);
		font-size: 0.85rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		border-bottom: none !important;
		transition: background 0.15s ease;
	}
	.cat-chip:hover {
		background: rgba(var(--accent), 0.18);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		.internal-links a {
			padding: 0.8em 0.3em;
			font-size: 0.95rem;
		}
	}
</style>
