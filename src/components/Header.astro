---
import { CATEGORIES, SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
	href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/');
---

<a class="skip-link" href="#main">본문으로 건너뛰기</a>
<header class="site-header" role="banner">
	<div class="header-top">
		<div class="container header-inner">
			<a href="/" class="brand" aria-label={`${SITE_TITLE} 홈으로`}>
				<span class="brand-mark" aria-hidden="true">📚</span>
				<span class="brand-name">{SITE_TITLE}</span>
				<span class="brand-tagline">정보 모아드립니다</span>
			</a>

			<nav class="nav-primary" aria-label="주요 메뉴">
				<a href="/" class:list={['nav-link', { active: isActive('/') }]}>홈</a>
				<a href="/blog" class:list={['nav-link', { active: isActive('/blog') }]}>블로그</a>
				<a
					href="/policy-feed"
					class:list={['nav-link', { active: isActive('/policy-feed') }]}>정책 피드</a
				>
				<a href="/about" class:list={['nav-link', { active: isActive('/about') }]}>소개</a>
			</nav>

			<div class="header-actions">
				<a href="/search" class="icon-btn" aria-label="검색">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="11" cy="11" r="8"></circle>
						<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
					</svg>
				</a>
				<a href="/rss.xml" class="icon-btn" aria-label="RSS 피드 구독">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
						<path
							d="M6.18 17.82a2.18 2.18 0 1 1-4.36 0 2.18 2.18 0 0 1 4.36 0M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"
						></path>
					</svg>
				</a>
				<button
					class="icon-btn menu-toggle"
					aria-label="메뉴 열기"
					aria-expanded="false"
					aria-controls="mobile-menu"
				>
					<svg
						viewBox="0 0 24 24"
						width="24"
						height="24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						aria-hidden="true"
					>
						<line x1="3" y1="6" x2="21" y2="6"></line>
						<line x1="3" y1="12" x2="21" y2="12"></line>
						<line x1="3" y1="18" x2="21" y2="18"></line>
					</svg>
				</button>
			</div>
		</div>
	</div>

	<nav class="category-strip" aria-label="카테고리">
		<div class="container">
			<ul class="chip-list">
				{
					CATEGORIES.map((c) => (
						<li>
							<a
								href={`/category/${c.slug}/`}
								class:list={[
									'chip',
									{ active: currentPath === `/category/${c.slug}` || currentPath === `/category/${c.slug}/` },
								]}
							>
								<span aria-hidden="true">{c.emoji}</span>
								<span>{c.label}</span>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</nav>

	<div id="mobile-menu" class="mobile-menu" hidden>
		<nav class="container" aria-label="모바일 메뉴">
			<a href="/" class="m-link">🏠 홈</a>
			<a href="/blog" class="m-link">📝 블로그</a>
			<a href="/policy-feed" class="m-link">📡 정책 피드</a>
			<a href="/search" class="m-link">🔍 검색</a>
			<a href="/about" class="m-link">ℹ️ 소개</a>
			<hr />
			<p class="m-section-title">카테고리</p>
			{
				CATEGORIES.map((c) => (
					<a href={`/category/${c.slug}/`} class="m-link">
						{c.emoji} {c.label}
					</a>
				))
			}
		</nav>
	</div>
</header>

<script is:inline>
	(function () {
		const toggle = document.querySelector('.menu-toggle');
		const menu = document.getElementById('mobile-menu');
		if (!toggle || !menu) return;
		toggle.addEventListener('click', function () {
			const opening = menu.hasAttribute('hidden');
			if (opening) {
				menu.removeAttribute('hidden');
				toggle.setAttribute('aria-expanded', 'true');
				toggle.setAttribute('aria-label', '메뉴 닫기');
			} else {
				menu.setAttribute('hidden', '');
				toggle.setAttribute('aria-expanded', 'false');
				toggle.setAttribute('aria-label', '메뉴 열기');
			}
		});
	})();
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: var(--z-header);
		background: rgba(255, 255, 255, 0.94);
		backdrop-filter: saturate(180%) blur(12px);
		-webkit-backdrop-filter: saturate(180%) blur(12px);
		border-bottom: 1px solid var(--border-default);
	}
	.header-top {
		padding: var(--space-3) 0;
	}
	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-5);
	}
	.brand {
		display: inline-flex;
		align-items: baseline;
		gap: var(--space-2);
		text-decoration: none;
		color: var(--text-heading);
	}
	.brand-mark {
		font-size: 1.4rem;
		line-height: 1;
	}
	.brand-name {
		font-size: var(--text-xl);
		font-weight: var(--weight-extrabold);
		letter-spacing: var(--tracking-tight);
	}
	.brand-tagline {
		font-size: var(--text-sm);
		color: var(--text-meta);
	}
	@media (max-width: 768px) {
		.brand-tagline {
			display: none;
		}
	}

	.nav-primary {
		display: flex;
		gap: var(--space-2);
	}
	.nav-link {
		color: var(--text-body);
		text-decoration: none;
		font-weight: var(--weight-medium);
		padding: var(--space-2) var(--space-3);
		border-radius: var(--radius-sm);
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		transition:
			color var(--duration-fast) var(--ease-out),
			background var(--duration-fast) var(--ease-out);
	}
	.nav-link:hover {
		color: var(--text-link);
		background: var(--bg-subtle);
		text-decoration: none;
	}
	.nav-link.active {
		color: var(--text-link);
		font-weight: var(--weight-semibold);
	}
	@media (max-width: 768px) {
		.nav-primary {
			display: none;
		}
	}

	.header-actions {
		display: flex;
		gap: var(--space-2);
	}
	.icon-btn {
		width: 44px;
		height: 44px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--text-body);
		background: transparent;
		border: none;
		border-radius: var(--radius-md);
		cursor: pointer;
		text-decoration: none;
	}
	.icon-btn:hover {
		background: var(--bg-subtle);
		color: var(--text-link);
	}
	.icon-btn:focus-visible {
		outline: none;
		box-shadow: var(--shadow-focus);
	}
	.menu-toggle {
		display: none;
	}
	@media (max-width: 768px) {
		.menu-toggle {
			display: inline-flex;
		}
	}

	.category-strip {
		border-top: 1px solid var(--border-default);
		background: var(--bg-card);
	}
	.chip-list {
		display: flex;
		gap: var(--space-2);
		list-style: none;
		margin: 0;
		padding: var(--space-3) 0;
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
	}
	.chip-list::-webkit-scrollbar {
		display: none;
	}
	.chip {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-2) var(--space-4);
		background: var(--bg-page);
		color: var(--text-body);
		border: 1px solid var(--border-default);
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		font-weight: var(--weight-medium);
		text-decoration: none;
		white-space: nowrap;
		scroll-snap-align: start;
		transition: all var(--duration-fast) var(--ease-out);
		min-height: 36px;
	}
	.chip:hover {
		border-color: var(--color-primary-300);
		color: var(--text-link);
	}
	.chip.active {
		background: var(--color-primary-700);
		color: white;
		border-color: var(--color-primary-700);
	}

	.mobile-menu {
		background: var(--bg-card);
		border-top: 1px solid var(--border-default);
		padding: var(--space-3) 0 var(--space-5);
	}
	.mobile-menu nav {
		display: flex;
		flex-direction: column;
	}
	.m-link {
		display: block;
		padding: var(--space-3) var(--space-2);
		text-decoration: none;
		color: var(--text-body);
		font-size: var(--text-lg);
		border-bottom: 1px solid var(--border-default);
		min-height: 44px;
	}
	.m-link:hover {
		color: var(--text-link);
		background: var(--bg-subtle);
	}
	.m-section-title {
		color: var(--text-meta);
		font-size: var(--text-sm);
		margin: var(--space-3) 0 var(--space-2);
		padding: 0 var(--space-2);
	}
</style>
