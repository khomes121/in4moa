---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`소개 · ${SITE_TITLE}`} description="인포모아 소개 — 만든 사람·운영 원칙·면책 사항" />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em 4em;
				color: rgb(var(--gray-dark));
				line-height: 1.7;
			}
			h1 {
				margin: 0 0 1em;
				line-height: 1.2;
			}
			h2 {
				margin: 1.8em 0 0.6em;
				font-size: 1.25rem;
				border-bottom: 1px solid rgba(var(--gray-light), 1);
				padding-bottom: 0.3em;
			}
			ul {
				padding-left: 1.2em;
			}
			.callout {
				background: rgba(var(--gray-light), 0.6);
				border-left: 4px solid rgba(var(--accent), 0.7);
				padding: 1em 1.2em;
				border-radius: 6px;
				margin: 1.2em 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>인포모아 소개</h1>

			<p>
				인포모아는 <strong>부동산·세금·대출·정부지원금·창업·계산기·뉴스</strong> 7개 카테고리에 흩어진 실생활 정보를 한곳에 모으는 정보 사이트입니다. 본업이 분양영업인 운영자가 일하면서 자주 묻거나 헷갈리는 질문을 답으로 정리해 올립니다.
			</p>

			<h2>운영 원칙</h2>
			<ul>
				<li><strong>출처와 기준일 명시</strong> — 모든 글은 공식 자료 링크와 작성·확인 시점을 표시합니다.</li>
				<li><strong>계산은 직접</strong> — 가이드 글 옆에는 본인 케이스로 계산할 수 있는 도구가 같이 옵니다.</li>
				<li><strong>시의성 글 분리</strong> — 자주 바뀌는 정책·금리·한도는 별도 카테고리로 분리해 옛 정보로 오인되지 않게 합니다.</li>
				<li><strong>입력값은 본인 브라우저에서</strong> — 계산기에 넣은 값은 인포모아 서버로 전송되지 않습니다.</li>
			</ul>

			<h2>다루는 것 / 다루지 않는 것</h2>
			<ul>
				<li><strong>다룹니다</strong> — 일반 정보, 공식 자료 정리, 계산 시뮬레이션, 절차 안내</li>
				<li><strong>다루지 않습니다</strong> — 개별 신청 대행, 1:1 상담, 특정 상품·매물 추천</li>
			</ul>

			<div class="callout">
				<strong>면책</strong> — 인포모아의 모든 글은 일반 정보 제공입니다. 본인 케이스가 복잡하거나 큰 금액이 걸린 결정은 반드시 <em>세무사·법무사·은행 담당자·중개사</em> 등 자격 있는 전문가와 확인하세요.
			</div>

			<h2>제안·오류 신고</h2>
			<p>
				사실 관계 오류·법령 변경·새로운 정책 정보는 언제든 알려주세요. 글 하단의 연락 경로 또는 (추후 추가될) 댓글로 받습니다.
			</p>
		</main>
		<Footer />
	</body>
</html>
