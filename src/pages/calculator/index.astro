---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CALCULATORS, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const calcPosts = (await getCollection('blog', ({ data }) => data.category === 'calculator')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`부동산·금융 계산기 모음 · ${SITE_TITLE}`}
			description="취득세·중개보수·DSR·청약가점·전월세 전환 — 부동산 거래에 필요한 계산기를 한 곳에. 입력값은 브라우저 안에서만 계산됩니다."
		/>
	</head>
	<body>
		<Header />
		<main id="main" class="container">
			<header class="hub-header">
				<h1>🧮 계산기 모음</h1>
				<p>
					부동산 거래·대출·청약에 바로 쓰는 계산기입니다. 입력한 값은
					<strong>본인 브라우저 안에서만</strong> 계산되며 서버로 전송되지 않습니다.
				</p>
			</header>

			<ul class="calc-list">
				{
					CALCULATORS.map((c) => (
						<li>
							<a href={`/calculator/${c.slug}/`} class="calc-item">
								<span class="calc-emoji" aria-hidden="true">
									{c.emoji}
								</span>
								<span>
									<span class="calc-name">{c.name}</span>
									<span class="calc-short">{c.short}</span>
								</span>
								<span class="calc-arrow" aria-hidden="true">
									→
								</span>
							</a>
						</li>
					))
				}
			</ul>

			{
				calcPosts.length > 0 && (
					<section class="hub-posts" aria-labelledby="calc-posts">
						<h2 id="calc-posts">계산기 활용 가이드</h2>
						<ul>
							{calcPosts.map((p) => (
								<li>
									<a href={`/blog/${p.id}/`}>{p.data.title}</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />

		<style>
			main {
				padding: var(--space-6) var(--space-4) var(--space-8);
				max-width: var(--container-lg);
			}
			.hub-header h1 {
				margin: 0 0 var(--space-3);
			}
			.hub-header p {
				color: var(--text-body);
				max-width: 640px;
			}
			.calc-list {
				list-style: none;
				margin: var(--space-6) 0 0;
				padding: 0;
				display: grid;
				gap: var(--space-3);
			}
			.calc-item {
				display: flex;
				align-items: center;
				gap: var(--space-4);
				padding: var(--space-4) var(--space-5);
				background: var(--bg-card);
				border: 1px solid var(--border-default);
				border-radius: var(--radius-lg);
				text-decoration: none;
				color: inherit;
				transition: all var(--duration-base) var(--ease-out);
			}
			.calc-item:hover {
				border-color: var(--color-primary-300);
				box-shadow: var(--shadow-md);
				text-decoration: none;
			}
			.calc-emoji {
				font-size: 1.8rem;
			}
			.calc-name {
				display: block;
				font-weight: var(--weight-bold);
				color: var(--text-heading);
				font-size: var(--text-lg);
			}
			.calc-short {
				display: block;
				color: var(--text-meta);
				font-size: var(--text-sm);
			}
			.calc-arrow {
				margin-left: auto;
				color: var(--text-link);
				font-weight: var(--weight-bold);
			}
			.hub-posts {
				margin-top: var(--space-7);
			}
		</style>
	</body>
</html>
