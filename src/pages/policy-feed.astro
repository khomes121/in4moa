---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { CATEGORIES, SITE_TITLE } from '../consts';
import { getPolicyFeed } from '../lib/policyFeed';

const all = await getPolicyFeed();
const filtered = all.filter((it) => it.category !== 'misc').slice(0, 80);
const groupedEntries = CATEGORIES.map((c) => ({
	cat: c,
	items: filtered.filter((it) => it.category === c.slug),
})).filter((g) => g.items.length > 0);
const totalCount = filtered.length;
const fetchedAt = new Date();
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`정책 브리핑 — ${SITE_TITLE}`}
			description="정부 보도자료를 인포모아 7대축으로 자동 분류한 라이브 피드. 정책브리핑(korea.kr) 출처."
		/>
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em 4em;
			}
			.hero {
				text-align: center;
				padding: 1em 0 2em;
			}
			.hero h1 {
				margin: 0 0 0.3em;
				font-size: 2.2rem;
			}
			.hero p {
				margin: 0.2em 0;
				color: rgb(var(--gray));
			}
			.hero .meta {
				font-size: 0.85rem;
			}
			.hero .meta a {
				color: rgb(var(--gray-dark));
			}
			.cat-block {
				margin: 2.4em 0;
			}
			.cat-block h2 {
				display: flex;
				align-items: baseline;
				gap: 0.4em;
				font-size: 1.35rem;
				margin: 0 0 0.8em;
				padding-bottom: 0.3em;
				border-bottom: 2px solid rgba(var(--accent), 0.4);
			}
			.cat-block h2 .count {
				font-size: 0.9rem;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.items {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.7em;
			}
			.items a {
				display: block;
				padding: 0.9em 1.1em;
				border-radius: 10px;
				background: white;
				border: 1px solid rgba(var(--gray-light), 1);
				text-decoration: none;
				color: rgb(var(--black));
				transition: border-color 0.15s ease;
			}
			.items a:hover {
				border-color: rgba(var(--accent), 0.6);
			}
			.items h3 {
				margin: 0 0 0.35em;
				font-size: 1.02rem;
				line-height: 1.35;
			}
			.item-meta {
				display: flex;
				gap: 0.6em;
				font-size: 0.8rem;
				color: rgb(var(--gray));
				margin: 0 0 0.35em;
				flex-wrap: wrap;
			}
			.ministry {
				display: inline-block;
				padding: 0 0.5em;
				background: rgba(var(--accent), 0.15);
				border-radius: 999px;
				color: rgb(var(--gray-dark));
				font-weight: 600;
			}
			.summary {
				margin: 0;
				font-size: 0.88rem;
				color: rgb(var(--gray));
				line-height: 1.45;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.empty {
				text-align: center;
				color: rgb(var(--gray));
				padding: 2em 0;
			}
			.disclaimer {
				margin-top: 3em;
				padding: 1em 1.2em;
				background: rgba(var(--gray-light), 0.6);
				border-left: 4px solid rgba(var(--accent), 0.6);
				border-radius: 6px;
				font-size: 0.88rem;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>📡 정책 브리핑</h1>
				<p>정부 보도자료를 인포모아 7대 카테고리로 자동 분류한 라이브 피드</p>
				<p class="meta">
					총 {totalCount}건 · <FormattedDate date={fetchedAt} /> 빌드 시 수집 · 출처:
					<a href="https://www.korea.kr" target="_blank" rel="noopener">정책브리핑(korea.kr)</a> · KOGL
					제1유형
				</p>
			</section>

			{
				totalCount === 0 ? (
					<p class="empty">
						현재 받아온 항목이 없습니다. RSS 응답 실패 또는 빌드 캐시 문제일 수 있어요. 잠시 후 다시 확인해주세요.
					</p>
				) : (
					groupedEntries.map(({ cat, items }) => (
						<section class="cat-block">
							<h2>
								<span>{cat.emoji}</span> {cat.label}{' '}
								<span class="count">{items.length}건</span>
							</h2>
							<ul class="items">
								{items.map((it) => (
									<li>
										<a href={it.link} target="_blank" rel="noopener">
											<p class="item-meta">
												<span class="ministry">{it.ministry}</span>
												<FormattedDate date={it.pubDate} />
											</p>
											<h3>{it.title}</h3>
											{it.summary && <p class="summary">{it.summary}</p>}
										</a>
									</li>
								))}
							</ul>
						</section>
					))
				)
			}

			<div class="disclaimer">
				<strong>이 페이지에 대해</strong> · 정부 보도자료 원문 링크를 인포모아 7대축으로 자동 분류해서 보여드립니다.
				원문 클릭 시 정책브리핑(korea.kr) 페이지로 이동합니다. 인포모아는 보도자료 본문을 저장·재배포하지 않으며,
				제목·부처·게재일·요약 일부만 인용합니다 (KOGL 제1유형 — 출처표시 후 자유 이용).
			</div>
		</main>
		<Footer />
	</body>
</html>
