---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`블로그 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main" class="container">
			<section class="blog-header">
				<h1>전체 글</h1>
				<p>총 {posts.length}편 · 최신순</p>
			</section>

			<ul class="post-list">
				{
					posts.map((post) => {
						const cat = CATEGORIES.find((c) => c.slug === post.data.category);
						return (
							<li class="post-card">
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<div class="post-thumb">
											<Image
												src={post.data.heroImage}
												alt={post.data.title}
												width={720}
												height={360}
											/>
										</div>
									)}
									<div class="post-body">
										<p class="post-meta">
											{cat && (
												<span class="post-cat">
													<span aria-hidden="true">{cat.emoji}</span> {cat.label}
												</span>
											)}
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h2 class="post-title">{post.data.title}</h2>
										{post.data.description && (
											<p class="post-desc">{post.data.description}</p>
										)}
									</div>
								</a>
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />

		<style>
			main {
				padding: var(--space-6) var(--space-4) var(--space-8);
				max-width: var(--container-lg);
			}
			.blog-header {
				margin-bottom: var(--space-6);
				padding-bottom: var(--space-4);
				border-bottom: 1px solid var(--border-default);
			}
			.blog-header h1 {
				margin: 0 0 var(--space-2);
				font-size: var(--text-3xl);
			}
			.blog-header p {
				margin: 0;
				color: var(--text-meta);
				font-size: var(--text-sm);
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: var(--space-4);
			}
			.post-card a {
				display: block;
				background: var(--bg-card);
				border: 1px solid var(--border-default);
				border-radius: var(--radius-lg);
				overflow: hidden;
				text-decoration: none;
				color: inherit;
				transition: all var(--duration-base) var(--ease-out);
			}
			.post-card a:hover {
				border-color: var(--color-primary-300);
				box-shadow: var(--shadow-md);
				text-decoration: none;
			}
			.post-thumb :global(img) {
				width: 100%;
				height: auto;
				display: block;
			}
			.post-body {
				padding: var(--space-4) var(--space-5);
			}
			.post-meta {
				display: flex;
				gap: var(--space-2);
				font-size: var(--text-xs);
				color: var(--text-meta);
				margin: 0 0 var(--space-2);
				align-items: center;
				flex-wrap: wrap;
			}
			.post-cat {
				color: var(--text-link);
				font-weight: var(--weight-semibold);
			}
			.post-title {
				margin: 0 0 var(--space-2);
				font-size: var(--text-xl);
				font-weight: var(--weight-semibold);
				color: var(--text-heading);
				line-height: var(--leading-snug);
			}
			.post-desc {
				margin: 0;
				color: var(--text-meta);
				font-size: var(--text-sm);
				line-height: var(--leading-normal);
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
		</style>
	</body>
</html>
