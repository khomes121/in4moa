---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { CALCULATORS, CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = allPosts.slice(0, 8);

const counts: Record<string, { count: number; latest?: Date }> = {};
for (const p of allPosts) {
	const slug = p.data.category;
	if (!counts[slug]) counts[slug] = { count: 0 };
	counts[slug].count += 1;
	if (!counts[slug].latest || p.data.pubDate > counts[slug].latest) {
		counts[slug].latest = p.data.pubDate;
	}
}
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="hero">
				<div class="container hero-inner">
					<p class="hero-eyebrow">한국 생활정보 종합 블로그</p>
					<h1 class="hero-title">
						복잡한 정보를 <span class="accent">한 줄로</span> 모아드립니다
					</h1>
					<p class="hero-lead">
						부동산·세금·대출·정부지원금·창업·계산기·뉴스까지. 40~60대가 자주 찾는 정보를 공식
						출처와 함께 알기 쉽게 정리합니다.
					</p>
					<div class="hero-cta">
						<a href="/blog" class="btn btn-primary">최근 글 보기 →</a>
						<a href="/policy-feed" class="btn btn-ghost">정책 피드 보기</a>
					</div>
					<p class="hero-meta">📌 매주 업데이트 · 출처 100% 명시 · 광고 최소</p>
				</div>
			</section>

			<section class="calc-section container" aria-labelledby="calc-heading">
				<h2 id="calc-heading" class="section-title">🧮 바로 쓰는 계산기</h2>
				<p class="section-desc">취득세·복비·DSR·청약가점 — 입력값은 브라우저 안에서만 계산됩니다.</p>
				<ul class="calc-strip">
					{
						CALCULATORS.map((c) => (
							<li>
								<a href={`/calculator/${c.slug}/`}>
									<span aria-hidden="true">{c.emoji}</span> {c.name}
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="category-section container" aria-labelledby="cat-heading">
				<h2 id="cat-heading" class="section-title">카테고리</h2>
				<p class="section-desc">관심 주제를 골라 정보를 찾아보세요.</p>

				<ul class="category-grid">
					{
						CATEGORIES.map((c) => {
							const meta = counts[c.slug];
							return (
								<li class="cat-card">
									<a href={`/category/${c.slug}/`}>
										<span class="cat-icon" aria-hidden="true">
											{c.emoji}
										</span>
										<h3 class="cat-name">{c.label}</h3>
										<p class="cat-desc">{c.description}</p>
										<p class="cat-meta">
											<span>글 {meta?.count ?? 0}편</span>
											{meta?.latest && (
												<>
													<span aria-hidden="true">·</span>
													<span>최근 <FormattedDate date={meta.latest} /></span>
												</>
											)}
										</p>
										<span class="cat-arrow" aria-hidden="true">
											→
										</span>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>

			<section class="recent-section container" aria-labelledby="recent-heading">
				<h2 id="recent-heading" class="section-title">최근 글</h2>
				<p class="section-desc">새로 올라온 글을 한눈에.</p>

				<ul class="recent-grid">
					{
						recentPosts.map((post) => {
							const cat = CATEGORIES.find((c) => c.slug === post.data.category);
							return (
								<li class="post-card">
									<a href={`/blog/${post.id}/`}>
										<p class="post-card-meta">
											{cat && (
												<span class="post-card-cat">
													<span aria-hidden="true">{cat.emoji}</span> {cat.label}
												</span>
											)}
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h3 class="post-card-title">{post.data.title}</h3>
										<p class="post-card-desc">{post.data.description}</p>
									</a>
								</li>
							);
						})
					}
				</ul>

				<div class="more-link">
					<a href="/blog" class="btn btn-ghost">전체 글 보기 →</a>
				</div>
			</section>
		</main>
		<Footer />

		<style>
			.hero {
				background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--bg-page) 100%);
				padding: var(--space-8) 0 var(--space-7);
			}
			.hero-inner {
				text-align: center;
				max-width: 800px;
			}
			.hero-eyebrow {
				font-size: var(--text-sm);
				color: var(--text-link);
				font-weight: var(--weight-semibold);
				letter-spacing: var(--tracking-wide);
				margin: 0 0 var(--space-3);
				text-transform: uppercase;
			}
			.hero-title {
				font-size: var(--text-5xl);
				font-weight: var(--weight-extrabold);
				line-height: var(--leading-tight);
				margin: 0 0 var(--space-4);
				letter-spacing: var(--tracking-tight);
			}
			@media (max-width: 768px) {
				.hero-title {
					font-size: var(--text-4xl);
				}
			}
			.hero-title .accent {
				color: var(--color-accent-500);
			}
			.hero-lead {
				font-size: var(--text-lg);
				color: var(--text-body);
				line-height: var(--leading-relaxed);
				margin: 0 auto var(--space-5);
				max-width: 640px;
			}
			.hero-cta {
				display: flex;
				gap: var(--space-3);
				justify-content: center;
				flex-wrap: wrap;
				margin-bottom: var(--space-5);
			}
			.hero-meta {
				color: var(--text-meta);
				font-size: var(--text-sm);
				margin: 0;
			}

			.calc-section {
				padding: var(--space-7) var(--space-4) 0;
			}
			.calc-strip {
				display: flex;
				gap: var(--space-3);
				flex-wrap: wrap;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.calc-strip a {
				display: inline-flex;
				align-items: center;
				gap: var(--space-2);
				padding: var(--space-3) var(--space-4);
				background: var(--bg-card);
				border: 1px solid var(--border-default);
				border-radius: var(--radius-full);
				text-decoration: none;
				color: var(--text-heading);
				font-weight: var(--weight-semibold);
				font-size: var(--text-sm);
				transition: all var(--duration-fast) var(--ease-out);
			}
			.calc-strip a:hover {
				border-color: var(--color-primary-300);
				color: var(--text-link);
				box-shadow: var(--shadow-md);
				text-decoration: none;
			}

			.category-section {
				padding: var(--space-7) var(--space-4);
			}
			.category-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: var(--space-4);
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.cat-card a {
				display: block;
				padding: var(--space-5);
				background: var(--bg-card);
				border: 1px solid var(--border-default);
				border-radius: var(--radius-lg);
				text-decoration: none;
				color: inherit;
				transition: all var(--duration-base) var(--ease-out);
				position: relative;
				min-height: 180px;
				height: 100%;
			}
			.cat-card a:hover {
				transform: translateY(-3px);
				box-shadow: var(--shadow-lg);
				border-color: var(--color-primary-300);
				text-decoration: none;
			}
			.cat-icon {
				font-size: 2rem;
				display: block;
				line-height: 1;
				margin-bottom: var(--space-3);
			}
			.cat-name {
				font-size: var(--text-xl);
				font-weight: var(--weight-bold);
				margin: 0 0 var(--space-2);
				color: var(--text-heading);
			}
			.cat-desc {
				margin: 0 0 var(--space-3);
				color: var(--text-body);
				font-size: var(--text-sm);
				line-height: var(--leading-normal);
			}
			.cat-meta {
				display: flex;
				gap: var(--space-2);
				color: var(--text-meta);
				font-size: var(--text-xs);
				margin: 0;
			}
			.cat-arrow {
				position: absolute;
				right: var(--space-5);
				bottom: var(--space-4);
				color: var(--text-link);
				font-weight: var(--weight-bold);
				transition: transform var(--duration-fast) var(--ease-out);
			}
			.cat-card a:hover .cat-arrow {
				transform: translateX(4px);
			}

			.recent-section {
				padding: 0 var(--space-4) var(--space-8);
			}
			.recent-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: var(--space-4);
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-card a {
				display: block;
				padding: var(--space-4);
				background: var(--bg-card);
				border: 1px solid var(--border-default);
				border-radius: var(--radius-lg);
				text-decoration: none;
				color: inherit;
				transition: all var(--duration-base) var(--ease-out);
				height: 100%;
			}
			.post-card a:hover {
				border-color: var(--color-primary-300);
				box-shadow: var(--shadow-md);
				text-decoration: none;
			}
			.post-card-meta {
				display: flex;
				gap: var(--space-2);
				font-size: var(--text-xs);
				color: var(--text-meta);
				margin: 0 0 var(--space-2);
				flex-wrap: wrap;
				align-items: center;
			}
			.post-card-cat {
				color: var(--text-link);
				font-weight: var(--weight-semibold);
			}
			.post-card-title {
				margin: 0 0 var(--space-2);
				font-size: var(--text-lg);
				font-weight: var(--weight-semibold);
				line-height: var(--leading-snug);
				color: var(--text-heading);
			}
			.post-card-desc {
				margin: 0;
				font-size: var(--text-sm);
				color: var(--text-meta);
				line-height: var(--leading-normal);
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.more-link {
				text-align: center;
				margin-top: var(--space-6);
			}
		</style>
	</body>
</html>
