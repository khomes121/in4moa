---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	return CATEGORIES.map((c) => ({
		params: { name: c.slug },
		props: { category: c },
	}));
}

const { category } = Astro.props;
const posts = (await getCollection('blog'))
	.filter((p) => p.data.category === category.slug)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latest = posts[0]?.data.pubDate;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`${category.label} · ${SITE_TITLE}`} description={category.description} />
	</head>
	<body>
		<Header />
		<main id="main" class="container">
			<nav class="crumbs" aria-label="이동 경로">
				<a href="/">홈</a>
				<span aria-hidden="true">›</span>
				<a href="/blog">블로그</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{category.label}</span>
			</nav>

			<section class="cat-header">
				<span class="cat-emoji" aria-hidden="true">{category.emoji}</span>
				<h1 class="cat-label">{category.label}</h1>
				<p class="cat-desc">{category.description}</p>
				<p class="cat-stats">
					<span>총 {posts.length}편</span>
					{
						latest && (
							<>
								<span aria-hidden="true">·</span>
								<span>최근 업데이트 <FormattedDate date={latest} /></span>
							</>
						)
					}
				</p>
			</section>

			{
				posts.length === 0 ? (
					<p class="empty">아직 글이 없습니다. 곧 채워집니다.</p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h2 class="post-title">{post.data.title}</h2>
									{post.data.description && (
										<p class="post-desc">{post.data.description}</p>
									)}
									<p class="post-meta">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />

		<style>
			main {
				padding: var(--space-6) var(--space-4) var(--space-8);
				max-width: var(--container-lg);
			}
			.crumbs {
				display: flex;
				gap: var(--space-2);
				font-size: var(--text-sm);
				color: var(--text-meta);
				margin-bottom: var(--space-5);
			}
			.crumbs a {
				color: var(--text-meta);
				text-decoration: none;
			}
			.crumbs a:hover {
				color: var(--text-link);
			}
			.cat-header {
				text-align: center;
				padding: var(--space-5) 0 var(--space-7);
			}
			.cat-emoji {
				font-size: 3.5rem;
				display: block;
				margin-bottom: var(--space-3);
				line-height: 1;
			}
			.cat-label {
				margin: 0 0 var(--space-2);
				font-size: var(--text-4xl);
				font-weight: var(--weight-extrabold);
				letter-spacing: var(--tracking-tight);
			}
			@media (max-width: 768px) {
				.cat-label {
					font-size: var(--text-3xl);
				}
			}
			.cat-desc {
				margin: 0 auto var(--space-3);
				color: var(--text-body);
				max-width: 560px;
			}
			.cat-stats {
				display: flex;
				justify-content: center;
				gap: var(--space-2);
				color: var(--text-meta);
				font-size: var(--text-sm);
				margin: 0;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: var(--space-3);
				max-width: var(--content-prose);
				margin-left: auto;
				margin-right: auto;
			}
			.post-list a {
				display: block;
				padding: var(--space-4) var(--space-5);
				background: var(--bg-card);
				border: 1px solid var(--border-default);
				border-radius: var(--radius-lg);
				text-decoration: none;
				color: inherit;
				transition: all var(--duration-base) var(--ease-out);
			}
			.post-list a:hover {
				border-color: var(--color-primary-300);
				box-shadow: var(--shadow-md);
				text-decoration: none;
			}
			.post-title {
				margin: 0 0 var(--space-2);
				font-size: var(--text-xl);
				font-weight: var(--weight-semibold);
				color: var(--text-heading);
				line-height: var(--leading-snug);
			}
			.post-desc {
				margin: 0 0 var(--space-2);
				color: var(--text-meta);
				font-size: var(--text-sm);
				line-height: var(--leading-normal);
			}
			.post-meta {
				margin: 0;
				font-size: var(--text-xs);
				color: var(--text-meta);
			}
			.empty {
				text-align: center;
				color: var(--text-meta);
				padding: var(--space-7) 0;
			}
		</style>
	</body>
</html>
